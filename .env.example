# ─── Backend (Railway) ───────────────────────────────────────────

# Groq API key for AI chat assistant
# Get one at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Telegram bot token from @BotFather
# Create a bot at https://t.me/botfather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your personal Telegram chat ID (not bot token, not bot username)
# Use @userinfobot to find your ID
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Comma-separated allowed CORS origins
# Railway auto-assigns a *.railway.app domain; add custom domain too
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-domain.vercel.app

# SQLite (dev) or PostgreSQL (prod via Railway)
# Railway provides a DATABASE_URL env var automatically if you attach Postgres plugin
DATABASE_URL=sqlite:///./app/data/portfolio.db

# Groq model to use
AI_MODEL=llama-3.3-70b-versatile

# ─── Frontend (Vercel) ────────────────────────────────────────────

# Full URL of the deployed backend (Railway URL or custom domain)
# Do NOT include trailing slash
VITE_API_URL=https://your-backend.railway.app
